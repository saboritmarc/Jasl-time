document.getElementById(‘clock-status-tag’).innerHTML=’<span class="tag '+st.cls+'">’+st.label+’</span>’;
document.getElementById(‘stat-worked’).textContent=minsToHM(s&&s.worked_minutes?s.worked_minutes:0);
